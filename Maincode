-- [ FUNGSI KEPALA & RAMBUT - FORCE SCAN ]
local function applyBodyMod(char)
    if not char then return end
    task.wait(0.5)
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
            if v.Name == "Head" then
                v.Transparency = States.Head
                if v:FindFirstChildOfClass("Decal") then v:FindFirstChildOfClass("Decal").Transparency = States.Head end
            elseif v.Name:find("Torso") then v.Transparency = States.Torso
            elseif v.Name:find("Arm") or v.Name:find("Hand") then v.Transparency = States.Arms
            elseif v.Name:find("Leg") or v.Name:find("Foot") then v.Transparency = States.Legs end
        end
    end
    for _, acc in pairs(char:GetChildren()) do
        if acc:IsA("Accessory") and acc:FindFirstChild("Handle") then
            local handle = acc.Handle
            local isHead = false
            for _, att in pairs(handle:GetChildren()) do
                if att:IsA("Attachment") then
                    local n = att.Name:lower()
                    if n:find("hair") or n:find("hat") or n:find("face") or n:find("head") or n:find("neck") then
                        isHead = true
                        break
                    end
                end
            end
            if isHead or acc.Name:lower():find("hair") or acc.Name:lower():find("hat") then
                handle.Transparency = States.Head
            else
                handle.Transparency = States.Torso
            end
        end
    end
end

-- [ FUNGSI PEMBERSIH EMOTE ]
local function KillEmoteGui()
    local CAS = game:GetService("ContextActionService")
    local CG = game:GetService("CoreGui")
    local PG = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
    local targets = {"Emotes", "EmoteGUI", "Emote Menu"}
    for _, name in pairs(targets) do
        if CG:FindFirstChild(name) then CG[name]:Destroy() end
        if PG and PG:FindFirstChild(name) then PG[name]:Destroy() end
    end
    pcall(function() CAS:UnbindCoreAction("Emote Menu") end)
    for _, v in pairs(CG:GetDescendants()) do
        if v:IsA("TextButton") and (v.Text == "Open" or v.Text == "Close") and v.Name == "Open" then
            v.Parent:Destroy()
        end
    end
end

-- [ LOGIC TOUCH TELEPORT ]
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or not States.TouchTP then return end
    
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local ray = Camera:ScreenPointToRay(input.Position.X, input.Position.Y)
            local raycastParams = RaycastParams.new()
            raycastParams.FilterDescendantsInstances = {char}
            raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
            
            local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
            if result then
                char.HumanoidRootPart.CFrame = CFrame.new(result.Position + Vector3.new(0, 3, 0))
                Rayfield:Notify({Title = "Teleport", Content = "Berhasil teleport ke lokasi!", Duration = 2})
            end
        end
    end
end)

-- [ LOGIC LOOP ]
local RunService = game:GetService("RunService")
RunService.Stepped:Connect(function()
    if States.Noclip then
        local char = game.Players.LocalPlayer.Character
        if char then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
    if States.ESP then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p.Character and p ~= game.Players.LocalPlayer then
                local highlight = p.Character:FindFirstChild("kacang55_ESP") or Instance.new("Highlight")
                highlight.Name = "kacang55_ESP"
                highlight.Parent = p.Character
                highlight.FillColor = Color3.fromRGB(255, 0, 0)
                highlight.Enabled = true
                highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            end
        end
    end
end)

