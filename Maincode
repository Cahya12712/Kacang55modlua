-- Variabel State
local States = {
    Head = 0, Torso = 0, Arms = 0, Legs = 0,
    WalkSpeed = 16, JumpPower = 50,
    AutoApply = true, Noclip = false
}

-- Fungsi Pencari Rambut & Aksesori Kepala (Metode Scan Mendalam)
local function applyBodyMod(char)
    if not char then return end
    task.wait(0.5) -- Jeda agar rambut ter-render sempurna

    -- 1. Part Tubuh Utama (Daging)
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
            if v.Name == "Head" then
                v.Transparency = States.Head
                if v:FindFirstChildOfClass("Decal") then v:FindFirstChildOfClass("Decal").Transparency = States.Head end
            elseif v.Name:find("Torso") then
                v.Transparency = States.Torso
            elseif v.Name:find("Arm") or v.Name:find("Hand") then
                v.Transparency = States.Arms
            elseif v.Name:find("Leg") or v.Name:find("Foot") then
                v.Transparency = States.Legs
            end
        end
    end

    -- 2. Scan Aksesori Khusus (Rambut/Topi)
    for _, acc in pairs(char:GetChildren()) do
        if acc:IsA("Accessory") then
            local handle = acc:FindFirstChild("Handle")
            if handle then
                local isHeadItem = false
                for _, attach in pairs(handle:GetChildren()) do
                    if attach:IsA("Attachment") then
                        local n = attach.Name:lower()
                        if n:find("hair") or n:find("hat") or n:find("face") or n:find("head") or n:find("neck") then
                            isHeadItem = true
                        end
                    end
                end
                
                if isHeadItem then
                    handle.Transparency = States.Head
                else
                    handle.Transparency = States.Torso
                end
            end
        end
    end
end

-- Logic Noclip
local RunService = game:GetService("RunService")
RunService.Stepped:Connect(function()
    if States.Noclip then
        local char = game.Players.LocalPlayer.Character
        if char then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
end)

